# domovina-fiskal-app — okolina. Kopiraj u .env.local i popuni.
# Sve su vrijednosti PUBLIC-SAFE (idu u client bundle) — ali .env.local ostaje
# izvan repoa da lokalne varijante ne cure u main.

# Dijeljeni Supabase/GoTrue SSO (domovina-api). Anon key je javno-siguran.
NEXT_PUBLIC_SUPABASE_URL="https://api.domovina.ai"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Fiskal API (Cloudflare Worker). Za lokalni razvoj: http://localhost:8787/api/v1
NEXT_PUBLIC_FISKAL_API_URL="https://fiskal.domovina.ai/api/v1"
